{
  "metrics": ["revenue"],
  "dimensions": [
    { "name": "orders.created_at", "time_grain": "month" },
    { "name": "orders.region" }
  ],
  "filters": [
    { "field": "orders.status", "op": "eq", "value": "completed" },
    {
      "field": "orders.created_at",
      "op": "between",
      "value": ["2025-01-01", "2025-12-31"]
    }
  ],
  "limit": 1000,
  "order_by": [{ "field": "revenue", "direction": "desc" }]
}
